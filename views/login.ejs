<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Todo App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>
    <div class="container" style="max-width: 400px;">
        <h1>Login</h1>
        <form class="todo-form" method="POST" action="/login">
            <% if (error) { %>
                <p style="color: var(--error); font-size: 0.85rem; margin-bottom: 1rem; text-align: center;"><%= error %></p>
            <% } %>
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Sign In</button>
            <p style="text-align: center; margin-top: 1.5rem; color: var(--text-muted); font-size: 0.9rem;">
                New here? <a href="/signup" style="color: var(--primary);">Create an account</a>.
            </p>
        </form>
    </div>
</body>
</html>
