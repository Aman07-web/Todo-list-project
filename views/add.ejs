<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Task | Todo App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>
    <div class="container" style="max-width: 500px;">
        <h1>Add New Task</h1>
        <form class="todo-form" method="POST" action="/add" autocomplete="off">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" placeholder="What needs to be done?" required>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea name="description" placeholder="Add more details..." rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Create Task</button>
            <a href="/user-dashboard" style="display: block; text-align: center; margin-top: 1rem; color: var(--text-muted); text-decoration: none; font-size: 0.9rem;">Back to Dashboard</a>
        </form>
    </div>
</body>
</html>
