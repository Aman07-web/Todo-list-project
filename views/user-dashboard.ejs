<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Dashboard | Todo App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>
    <div class="container">
        <h1>My Dashboard</h1>

        <div class="todo-grid">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <h2 style="font-size: 1.25rem;">Tasks for <span style="color: var(--primary);"><%= username %></span></h2>
                <a href="/add" class="btn btn-primary" style="font-size: 0.8rem;">+ New Task</a>
            </div>

            <% if (todos.length > 0) { %>
                <% todos.forEach(todo => { %>
                    <div class="todo-card">
                        <div class="todo-content">
                            <h3 class="todo-title"><%= todo.title %></h3>
                            <p class="todo-desc"><%= todo.description %></p>
                            <span style="font-size: 0.7rem; color: var(--text-muted); display: block; margin-top: 0.5rem;">
                                Added on <%= new Date(todo.createdAt).toLocaleDateString() %>
                            </span>
                        </div>
                        <div class="todo-actions">
                            <a href="/update/<%= todo._id %>" class="btn btn-edit">Edit</a>
                            <form action="/delete/<%= todo._id %>" method="POST" onsubmit="return confirm('Delete this task?');">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; padding: 4rem; background: #fff; border: 2px dashed var(--border); border-radius: 0.75rem;">
                    <p style="color: var(--text-muted); margin-bottom: 1.5rem;">You haven't added any tasks yet.</p>
                    <a href="/add" class="btn btn-primary">Create Your First Task</a>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
