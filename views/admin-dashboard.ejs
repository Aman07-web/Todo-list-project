<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Tasks | Todo App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>
    <div class="container">
        <h1>Recent Tasks</h1>
        
        <div class="todo-grid">
            <% if (todos.length > 0) { %>
                <% todos.forEach(todo => { %>
                    <div class="todo-card">
                        <div class="todo-content">
                            <span class="todo-user">Created by <%= todo.username %></span>
                            <h3 class="todo-title text-main"><%= todo.title %></h3>
                            <p class="todo-desc"><%= todo.description %></p>
                        </div>
                        <div class="todo-actions">
                            <% if (user && user.username === todo.username) { %>
                                <a href="/update/<%= todo._id %>" class="btn btn-edit">Edit</a>
                                <form action="/delete/<%= todo._id %>" method="POST" onsubmit="return confirm('Delete this task?');">
                                    <button type="submit" class="btn btn-danger">Delete</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
                    No tasks found. Get started by adding one!
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
