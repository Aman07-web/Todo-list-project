<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Task</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>
    <h1>Update Task</h1>
    <div class="container">
        <form class="todo-form" method="post" action="/update" autocomplete="off">
            <input type="text" name="title" placeholder="Enter your title" autocomplete="off"><br><br>
            <textarea name="description" placeholder="Enter your description" autocomplete="off"></textarea><br><br>
            <button>Update Task</button>
        </form>
    </div>
</body>
</html>
